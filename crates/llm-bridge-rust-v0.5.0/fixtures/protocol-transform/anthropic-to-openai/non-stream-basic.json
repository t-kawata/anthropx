{
  "name": "anthropic_to_openai_non_stream_basic",
  "mode": "non_stream",
  "notes": "Minimal Anthropic request mapped to OpenAI Chat with system prompt and text message.",
  "input": {
    "headers": {
      "x-api-key": "ANTHROPIC_API_KEY_PLACEHOLDER",
      "content-type": "application/json"
    },
    "path": "/v1/messages",
    "body": {
      "model": "claude-sonnet-4-20250514",
      "max_tokens": 256,
      "system": "You are a concise assistant.",
      "messages": [
        {
          "role": "user",
          "content": [
            {
              "type": "text",
              "text": "Say hello in one sentence."
            }
          ]
        }
      ]
    }
  },
  "expected": {
    "headers": {
      "authorization": "Bearer ANTHROPIC_API_KEY_PLACEHOLDER",
      "content-type": "application/json"
    },
    "path": "/v1/chat/completions",
    "body": {
      "model": "claude-sonnet-4-20250514",
      "max_tokens": 256,
      "messages": [
        {
          "role": "system",
          "content": "You are a concise assistant."
        },
        {
          "role": "user",
          "content": "Say hello in one sentence."
        }
      ]
    }
  }
}